{
  "name": "node-map",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#server": "./server.ts",
    "#src/*": "./src/*"
  },
  "scripts": {
    "clean": "rm -rf .wrangler dist",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "format": "oxfmt --ignore-path .gitignore --ignore-path .oxignore --write .",
    "format:check": "oxfmt --ignore-path .gitignore --ignore-path .oxignore --check .",
    "lint": "oxlint . --ignore-path .gitignore --ignore-pattern migrations/** --ignore-pattern src/routeTree.gen.ts --type-aware --type-check --react-plugin --vitest-plugin",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "check": "pnpm run format:check && pnpm run lint && pnpm run typecheck",
    "knip": "knip",
    "test": "vitest run --config ./vitest.config.ts",
    "deploy": "pnpm run build && wrangler deploy",
    "types": "wrangler types ./worker-configuration.d.ts --include-runtime false",
    "db:generate": "node ./scripts/generate-migrations.mjs",
    "db:migrate": "yes | wrangler d1 migrations apply node-map --local --config ./wrangler.jsonc",
    "db:migrate:remote": "wrangler d1 migrations apply node-map --remote --config ./wrangler.jsonc",
    "db:promote-user": "node ./scripts/promote-user.mjs"
  },
  "dependencies": {
    "@formisch/react": "^0.4.5",
    "@hono/standard-validator": "^0.2.2",
    "@pixi/react": "^8.0.5",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-router": "^1.168.23",
    "better-auth": "^1.6.5",
    "drizzle-orm": "beta",
    "hono": "^4.12.14",
    "pixi.js": "^8.18.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.33.0",
    "@cloudflare/vitest-pool-workers": "^0.14.8",
    "@cloudflare/workers-types": "^4.20260421.1",
    "@tanstack/router-plugin": "^1.167.22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260421.1",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "beta",
    "knip": "^6.6.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "vite": "^8.0.9",
    "vitest": "^4.1.5",
    "wrangler": "^4.84.0"
  },
  "packageManager": "pnpm@10.33.0",
  "knip": {
    "entry": [
      "test/env.d.ts"
    ]
  }
}

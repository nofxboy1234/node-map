{
  "name": "@node-map/api",
  "private": true,
  "type": "module",
  "exports": {
    "./client": "./src/client.ts"
  },
  "scripts": {
    "dev": "XDG_CONFIG_HOME=./.wrangler-config wrangler dev",
    "types": "XDG_CONFIG_HOME=./.wrangler-config wrangler types ./worker-configuration.d.ts --include-runtime false",
    "build": "XDG_CONFIG_HOME=./.wrangler-config wrangler deploy --dry-run",
    "deploy": "XDG_CONFIG_HOME=./.wrangler-config wrangler deploy"
  },
  "dependencies": {
    "@hono/standard-validator": "^0.2.2",
    "@node-map/db": "workspace:*",
    "@node-map/shared": "workspace:*",
    "better-auth": "^1.5.6",
    "drizzle-orm": "1.0.0-beta.19",
    "hono": "^4.12.9"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260327.0",
    "wrangler": "^4.10.0"
  }
}

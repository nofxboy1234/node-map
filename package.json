{
  "name": "node-map",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#server": "./server.ts",
    "#src/*": "./src/*"
  },
  "scripts": {
    "clean": "rm -rf .wrangler dist",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "format": "oxfmt --ignore-path .gitignore --ignore-path .oxignore --write .",
    "format:check": "oxfmt --ignore-path .gitignore --ignore-path .oxignore --check .",
    "lint": "oxlint . --ignore-path .gitignore --ignore-pattern migrations/** --ignore-pattern src/routeTree.gen.ts --type-aware --type-check --react-plugin --vitest-plugin",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "check": "pnpm run format:check && pnpm run lint && pnpm run typecheck",
    "knip": "knip",
    "test": "vitest run --config ./vitest.config.ts",
    "deploy": "pnpm run build && wrangler deploy",
    "types": "wrangler types ./worker-configuration.d.ts --include-runtime false",
    "db:generate": "node ./scripts/generate-migrations.mjs",
    "db:migrate": "yes | wrangler d1 migrations apply node-map --local --config ./wrangler.jsonc",
    "db:migrate:remote": "wrangler d1 migrations apply node-map --remote --config ./wrangler.jsonc"
  },
  "dependencies": {
    "@hono/standard-validator": "^0.2.2",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-router": "^1.168.10",
    "better-auth": "^1.6.0",
    "drizzle-orm": "beta",
    "hono": "^4.12.12",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.31.1",
    "@cloudflare/vitest-pool-workers": "^0.14.2",
    "@cloudflare/workers-types": "^4.20260408.1",
    "@tanstack/router-plugin": "^1.167.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260406.1",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "beta",
    "knip": "^6.3.1",
    "oxfmt": "0.44.0",
    "oxlint": "1.59.0",
    "vite": "8.0.5",
    "vitest": "4.1.2",
    "wrangler": "^4.81.0"
  },
  "packageManager": "pnpm@10.33.0",
  "knip": {
    "entry": [
      "test/env.d.ts"
    ]
  }
}

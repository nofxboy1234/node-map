{
  "name": "node-map",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#server": "./server.ts",
    "#src/*": "./src/*"
  },
  "scripts": {
    "clean": "rm -rf .wrangler dist",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint . --ignore-path .gitignore",
    "typecheck": "tsgo",
    "check": "pnpm run format:check && pnpm run lint && pnpm run typecheck",
    "knip": "knip",
    "test": "vitest run",
    "deploy": "pnpm run build && wrangler deploy",
    "types": "wrangler types --include-runtime false",
    "db:generate": "node ./scripts/generate-migrations.mjs",
    "db:migrate": "yes | wrangler d1 migrations apply node-map --local",
    "db:migrate:remote": "wrangler d1 migrations apply node-map --remote",
    "db:promote-user": "node ./scripts/promote-user.mjs"
  },
  "dependencies": {
    "@formisch/react": "^0.4.5",
    "@hono/standard-validator": "^0.2.2",
    "@pixi/react": "^8.0.5",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-router": "^1.169.1",
    "better-auth": "^1.6.9",
    "drizzle-orm": "rc",
    "hono": "^4.12.16",
    "pixi.js": "^8.18.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.35.0",
    "@cloudflare/vitest-pool-workers": "^0.15.2",
    "@cloudflare/workers-types": "^4.20260505.1",
    "@tanstack/router-plugin": "^1.167.33",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260504.1",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "rc",
    "knip": "^6.11.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "wrangler": "^4.87.0"
  },
  "packageManager": "pnpm@10.33.3",
  "knip": {
    "entry": [
      "test/env.d.ts"
    ]
  }
}

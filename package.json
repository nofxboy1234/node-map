{
  "name": "node-map",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#server": "./server.ts",
    "#src/*": "./src/*"
  },
  "scripts": {
    "clean": "rm -rf .wrangler dist",
    "knip": "knip",
    "deploy": "vp build && wrangler deploy",
    "types": "wrangler types ./worker-configuration.d.ts --include-runtime false",
    "db:generate": "node ./scripts/generate-migrations.mjs",
    "db:migrate": "yes | wrangler d1 migrations apply node-map --local --config ./wrangler.jsonc",
    "db:migrate:remote": "wrangler d1 migrations apply node-map --remote --config ./wrangler.jsonc"
  },
  "dependencies": {
    "@hono/standard-validator": "^0.2.2",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-router": "^1.168.10",
    "better-auth": "^1.6.0",
    "drizzle-orm": "1.0.0-beta.19",
    "hono": "^4.12.11",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.31.0",
    "@cloudflare/workers-types": "^4.20260405.1",
    "@tanstack/router-plugin": "^1.167.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "drizzle-kit": "1.0.0-beta.19",
    "knip": "^6.3.0",
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.16",
    "vite-plus": "^0.1.16",
    "wrangler": "^4.80.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    },
    "peerDependencyRules": {
      "allowAny": [
        "vite",
        "vitest"
      ]
    }
  }
}

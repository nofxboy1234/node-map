{
  "name": "node-map",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf apps/api/.output apps/web/dist",
    "clean:deps": "find . -type d -name node_modules -prune -exec rm -rf '{}' + && rm -f pnpm-lock.yaml",
    "list:deps": "node ./scripts/list-deps.mjs",
    "knip": "knip",
    "dev:local": "./scripts/dev-local.sh",
    "preview:local": "./scripts/preview-local.sh",
    "dev:api": "vp run @node-map/api#dev",
    "dev:web": "vp run @node-map/web#dev",
    "build:api": "vp run @node-map/api#build",
    "build:web": "vp run @node-map/web#build"
  },
  "devDependencies": {
    "knip": "^6.1.0",
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.14",
    "vite-plus": "latest"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    },
    "peerDependencyRules": {
      "allowAny": [
        "vite",
        "vitest"
      ]
    }
  }
}

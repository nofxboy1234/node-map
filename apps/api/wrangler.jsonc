{
  "name": "node-map-api",
  "main": "server.ts",
  "compatibility_date": "2026-03-31",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "logs": {
      "head_sampling_rate": 1,
    },
    "traces": {
      "enabled": true,
      "head_sampling_rate": 0.01,
    },
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "node-map",
      "database_id": "8415827c-7fc3-4104-9a13-09438196e22c",
      "migrations_dir": "../../packages/db/migrations",
    },
  ],
}

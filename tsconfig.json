{
  "compilerOptions": {
    "target": "es2023",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "types": ["vite/client", "@cloudflare/workers-types"],
    "paths": {
      "#server": ["./server.ts"],
      "#src/*": ["./src/*"]
    }
  },
  "include": ["server.ts", "worker-configuration.d.ts", "src", "drizzle.config.ts"]
}
